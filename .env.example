# Resend (envio de e-mail real)
# Obtenha sua key em: https://resend.com/api-keys
RESEND_API_KEY=re_sua_key_aqui

# E-mail do Instituto Kalapa (remetente e destinatário das notificações)
KALAPA_EMAIL_FROM=contato@institutokalapa.com.br
KALAPA_EMAIL_TO=contato@institutokalapa.com.br

# Supabase (contagem real de vagas)
# Crie um projeto em: https://supabase.com
# SQL Editor > cole o conteúdo de supabase/schema.sql
# Settings > API > copie Project URL e anon key
NEXT_PUBLIC_SUPABASE_URL=https://seu_projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
