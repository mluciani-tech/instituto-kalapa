# Resend (envio de e-mail real)
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_sua_key_aqui

# E-mail do Instituto Kalapa (remetente e destinatário das notificações)
KALAPA_EMAIL_FROM=contato@institutokalapa.com.br
KALAPA_EMAIL_TO=contato@institutokalapa.com.br

# Supabase
# Projeto: https://supabase.com
# SQL Editor > cole o conteúdo de supabase/schema.sql
# Settings > API > copie Project URL, anon key e service_role key
NEXT_PUBLIC_SUPABASE_URL=https://seu_projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Supabase Service Role (server-side apenas — NUNCA expor no client)
# Obtenha em: Supabase Dashboard > Settings > API > service_role key
# Não use prefixo NEXT_ para evitar conflitos com o Next.js
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Admin (área restrita do painel administrativo)
# Use uma senha forte para acessar /admin
ADMIN_PASSWORD=sua_senha_admin_aqui

# SESSION_SECRET (obrigatório em produção — assina o cookie de sessão)
# Gere com: openssl rand -hex 32
SESSION_SECRET=sua_chave_secreta_aqui

# WEBHOOK_SECRET (verifica origem dos webhooks InfinitePay)
# Gere com: openssl rand -hex 32
# O checkout envia este segredo na webhook_url; sem ele, pagamentos falsos poderiam ser confirmados
WEBHOOK_SECRET=seu_webhook_secret_aqui

# InfinitePay Checkout
# Seu handle (InfiniteTag) no InfinitePay, sem o $
INFINITEPAY_HANDLE=kalapa

# URL do site (usado para redirect_url e webhook_url)
NEXT_PUBLIC_SITE_URL=https://seu-dominio.vercel.app
